# Required for Gemini AI features (interview, coach, resume parsing, etc.)
GEMINI_API_KEY="your-gemini-api-key-here"

# Public URL of your deployed app (use http://localhost:3000 for local dev)
APP_URL="http://localhost:3000"

# Firebase — enables real Google Sign-In (get these from Firebase Console → Project settings → Your apps → Web)
# When all six are set, the app uses real Google OAuth instead of the demo sandbox.
VITE_FIREBASE_API_KEY="your-firebase-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project-id.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="123456789012"
VITE_FIREBASE_APP_ID="1:123456789012:web:abcdef123456"
